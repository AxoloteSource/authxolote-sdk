{
  "name": "axolote-source/authxolote-sdk",
  "description": "Authxolote SDK",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Authxolote\\Sdk\\": "src/",
      "Authxolote\\Sdk\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Luis Ozuna"
    }
  ],
  "require": {
    "php": "^8.1|^8.2|^8.3|^8.4",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
    "spatie/laravel-data": "^3.0|^4.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Authxolote\\Sdk\\AuthxoloteServiceProvider"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5|^10.1|^11.0",
    "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0"
  }
}
